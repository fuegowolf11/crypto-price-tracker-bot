# Coins to monitor (comma separated, lowercase)
COINS=bitcoin,ethereum,solana

# Price alert thresholds (in USD) - Set to 0 to disable
# Upper alerts trigger when price goes ABOVE this value
# Lower alerts trigger when price goes BELOW this value

ALERT_BTC_UPPER=80000
ALERT_BTC_LOWER=70000

ALERT_ETH_UPPER=3000
ALERT_ETH_LOWER=2000

ALERT_SOL_UPPER=200
ALERT_SOL_LOWER=100
